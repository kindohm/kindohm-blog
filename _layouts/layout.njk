<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/style.css">

    <style>
      body {
        color: {{metadata.foreground}};
        background-color: {{metadata.background}};
      }

      a,
      a:active,
      a:link,
      a:visited {
        color: {{metadata.foreground}};
      }
    </style>

  </head>
  <body>
    <div class="container">
      <header>
        <a href="/">kindohm blog</a>
      </header>
      <main>
        {{ content | safe }}
      </main>
    </div>
  </body>
</html>